@echo off
set msg_dns=DNS cache flushed successfully.
set msg_kill=Background applications terminated.
set msg_temp=Temporary files cleared.
set msg_perf=High performance mode activated.

:start
cls
echo ===========================================
echo            SYSTEM OPTIMIZER TOOL
echo ===========================================
echo Discalmer: Standard system operations included.
echo Although this tool is designed to be safe, 
echo I do not take responsibility for any system 
echo instability or hardware issues that may occur.
echo ===========================================
echo 1. Flush DNS
echo 2. Terminate background processes
echo 3. Clear temporary files
echo 4. Enable High Performance mode
echo 5. Exit
echo.

set /p choice=Select an option (1-5): 

if %choice%==1 goto dns
if %choice%==2 goto kill
if %choice%==3 goto temp
if %choice%==4 goto perf
if %choice%==5 exit
goto start

:dns
echo Flushing DNS...
ipconfig /flushdns >nul
ipconfig /release >nul
ipconfig /renew >nul
echo %msg_dns%
pause
goto start

:kill
echo Terminating processes...
taskkill /f /im chrome.exe /t >nul
taskkill /f /im edge.exe /t >nul
echo %msg_kill%
pause
goto start

:temp
echo Clearing temporary files...
del /s /f /q %temp%\*.* >nul
echo %msg_temp%
pause
goto start

:perf
echo Applying high performance settings...
powercfg -setactive 8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c
echo %msg_perf%
pause
goto start
